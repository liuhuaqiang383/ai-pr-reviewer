# ============================================
# AI PR Review 助手 - 配置文件
# ============================================

# GitHub Configuration
GITHUB_TOKEN=your_github_token_here

# ============================================
# 默认AI提供商和模型
# ============================================
DEFAULT_AI_PROVIDER=openai
DEFAULT_AI_MODEL=gpt-4o

# ============================================
# 自定义提供商配置
# 方式1: 直接写JSON
# 方式2: 指向JSON配置文件路径
# ============================================
# CUSTOM_PROVIDERS={"my-llm": {"name": "My LLM", "type": "openai_compatible", "base_url": "http://my-server/v1", "api_key": "xxx", "model": "my-model"}}
# CUSTOM_PROVIDERS=./custom_providers.json
